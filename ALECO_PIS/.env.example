# --- Copy to .env for local development (never commit .env) ---

# Frontend: API base (local Node server)
VITE_API_URL=http://localhost:5000

# Optional: used only if VITE_API_URL is unset in a production build (e.g. Vercel can set VITE_API_URL instead)
# VITE_API_URL_PRODUCTION=https://your-public-api.example.com

# Google / maps (see your Google Cloud project)
# VITE_GOOGLE_CLIENT_ID=
# VITE_GOOGLE_MAPS_API_KEY=

# --- Backend (server.js) ---
# Comma-separated extra browser origins (defaults already include localhost + https://aleco-pis-x6zo.vercel.app)
# CORS_ALLOWED_ORIGINS=https://your-preview-branch.vercel.app
