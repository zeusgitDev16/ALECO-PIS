# --- Copy to .env for local development (never commit .env) ---

# Frontend: API base (local Node server)
VITE_API_URL=http://localhost:5000

# Optional: used only if VITE_API_URL is unset in a production build (e.g. Vercel can set VITE_API_URL instead)
# VITE_API_URL_PRODUCTION=https://your-public-api.example.com

# Google / maps (see your Google Cloud project)
# VITE_GOOGLE_CLIENT_ID=
# VITE_GOOGLE_MAPS_API_KEY=

# --- Backend (Render / server.js) ---
# Optional: public SPA URL (custom domain or extra Vercel URL) — added to CORS allowlist (no trailing slash)
# PUBLIC_APP_URL=https://aleco-pis-x6zo.vercel.app
# FRONTEND_ORIGIN=  (alias for PUBLIC_APP_URL)
# Comma-separated extra origins (e.g. Vercel preview deployments)
# CORS_ALLOWED_ORIGINS=https://aleco-pis-x6zo-git-zeus-xxx.vercel.app
