# --- Copy to .env for local development (never commit .env) ---

# Frontend: API base (local Node server)
VITE_API_URL=http://localhost:5000

# Optional: used only if VITE_API_URL is unset in a production build (e.g. Vercel can set VITE_API_URL instead)
# VITE_API_URL_PRODUCTION=https://your-public-api.example.com

# Google / maps (see your Google Cloud project)
# VITE_GOOGLE_CLIENT_ID=
# VITE_GOOGLE_MAPS_API_KEY=

# --- Backend (any Node host: Render, Fly, VPS, etc.) ---
# Required for deployed SPA + API: public SPA origin(s) — CORS allowlist (no trailing slash)
# Also used for optional "open the app" link in forgot-password emails.
# PUBLIC_APP_URL=https://your-frontend.example.com
# FRONTEND_ORIGIN=  (alias for PUBLIC_APP_URL)
# Comma-separated extra origins (preview deploys, staging)
# CORS_ALLOWED_ORIGINS=https://preview-abc.example.com,https://staging.example.com
