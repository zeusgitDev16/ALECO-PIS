# Cloudinary Configuration (required)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Frontend URL for poster capture (required)
PUBLIC_APP_URL_PRODUCTION=https://apisph.org
# Alternative: PUBLIC_APP_URL or FRONTEND_ORIGIN

# API Key for worker authentication (required)
# Generate a secure random key, e.g., using: openssl rand -base64 32
POSTER_WORKER_API_KEY=your_secure_random_api_key_here

# Optional: Puppeteer capture settings
POSTER_CAPTURE_VIEWPORT_WIDTH=1200
POSTER_CAPTURE_VIEWPORT_HEIGHT=1700
POSTER_CAPTURE_DEVICE_SCALE_FACTOR=3

# Cloud Run sets PORT automatically, but can override for local testing
PORT=8080
